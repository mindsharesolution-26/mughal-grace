# Mughal Grace API Environment Variables

# Node
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mughal_grace

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Multi-tenant
TENANT_SCHEMA_PREFIX=tenant_

# WhatsApp Business API (Meta Cloud)
# Get these from Meta Business Suite: https://business.facebook.com/
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/v1/whatsapp/webhook

# AI Service (Phase 2)
# AI_SERVICE_URL=http://localhost:8000
# OPENROUTER_API_KEY=

# Email (for password reset)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
