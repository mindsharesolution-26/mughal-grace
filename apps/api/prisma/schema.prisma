}

// --- YARN LEDGER (Inventory Tracking with Running Balance) ---

enum YarnLedgerEntryType {
  OPENING_BALANCE
  INWARD           // Purchase/Receipt from vendor
  OUTWARD          // Issue to production
  ADJUSTMENT       // Manual adjustment
  RETURN           // Return from production

  @@schema("tenant_template")
}

model YarnLedger {
  id                Int                  @id @default(autoincrement())
  yarnTypeId        Int                  @map("yarn_type_id")
  entryDate         DateTime             @map("entry_date") @db.Date
  entryType         YarnLedgerEntryType  @map("entry_type")

  // Quantity tracking (KG)
  quantityIn        Decimal              @default(0) @map("quantity_in") @db.Decimal(12, 3)
  quantityOut       Decimal              @default(0) @map("quantity_out") @db.Decimal(12, 3)
  runningBalance    Decimal              @map("running_balance") @db.Decimal(12, 3)

  // Pricing
  pricePerKg        Decimal?             @map("price_per_kg") @db.Decimal(12, 2)
  totalValue        Decimal?             @map("total_value") @db.Decimal(15, 2)

  // Reference to source document
  referenceType     String?              @map("reference_type") @db.VarChar(50)  // 'yarn_box', 'outward', 'adjustment'
  referenceId       Int?                 @map("reference_id")
  referenceNumber   String?              @map("reference_number") @db.VarChar(100)

  // Vendor & Invoice (for inward entries)
  vendorId          Int?                 @map("vendor_id")
  invoiceNumber     String?              @map("invoice_number") @db.VarChar(100)

  // Details
  description       String?              @db.Text
  notes             String?              @db.Text
  paymentStatus     PaymentStatus?       @map("payment_status")

  // Audit
  createdBy         Int?                 @map("created_by")
  createdAt         DateTime             @default(now()) @map("created_at")

  // Relations
  yarnType          YarnType             @relation(fields: [yarnTypeId], references: [id])
  vendor            YarnVendor?          @relation(fields: [vendorId], references: [id])

  @@index([yarnTypeId])
  @@index([entryDate])
  @@index([entryType])
  @@index([vendorId])
  @@index([referenceType, referenceId])
  @@map("yarn_ledger")
  @@schema("tenant_template")
}

// --- YARN OUTWARD (Issue to Machines) ---

enum YarnOutwardStatus {
  ISSUED
  IN_USE
  COMPLETED
  RETURNED

  @@schema("tenant_template")
}

model YarnOutward {
  id               Int               @id @default(autoincrement())
  outwardNumber    String            @unique @map("outward_number") @db.VarChar(50)

  // What was issued
  yarnTypeId       Int               @map("yarn_type_id")
  boxId            Int?              @map("box_id")
  quantityIssued   Decimal           @map("quantity_issued") @db.Decimal(12, 3)

  // Where it went
  machineId        Int               @map("machine_id")

  // Who and when
  issuedAt         DateTime          @map("issued_at")
  issuedBy         Int?              @map("issued_by")
  collectedBy      String            @map("collected_by") @db.VarChar(255)

  // Tracking
  status           YarnOutwardStatus @default(ISSUED)
  quantityReturned Decimal           @default(0) @map("quantity_returned") @db.Decimal(12, 3)
  quantityUsed     Decimal           @default(0) @map("quantity_used") @db.Decimal(12, 3)

  // Context
  shiftId          Int?              @map("shift_id")
  purpose          String            @default("PRODUCTION") @db.VarChar(50)
  notes            String?           @db.Text

  // Audit
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // Relations
  yarnType         YarnType          @relation(fields: [yarnTypeId], references: [id])
  box              YarnBox?          @relation(fields: [boxId], references: [id])
  machine          Machine           @relation(fields: [machineId], references: [id])
  shift            Shift?            @relation(fields: [shiftId], references: [id])

  @@index([yarnTypeId])
  @@index([machineId])
  @@index([issuedAt])
  @@index([status])
  @@map("yarn_outwards")
  @@schema("tenant_template")
}

// Knitting Machine Size Master (industry-specific)
model KnittingMachineSize {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)
  name         String    @db.VarChar(255)
  gauge        Int?                          // e.g., 18, 20, 22, 24
  diameter     Int?                          // in inches
