// --- VENDOR LEDGER (Unified for all vendor types) ---

model VendorLedgerEntry {
  id                Int              @id @default(autoincrement())
  vendorType        VendorType       @map("vendor_type")
  yarnVendorId      Int?             @map("yarn_vendor_id")
  dyeingVendorId    Int?             @map("dyeing_vendor_id")
  generalSupplierId Int?             @map("general_supplier_id")
  entryDate         DateTime         @map("entry_date") @db.Date
  entryType         VendorLedgerType @map("entry_type")
  debit             Decimal          @default(0) @db.Decimal(15, 2)
  credit            Decimal          @default(0) @db.Decimal(15, 2)
  balance           Decimal          @db.Decimal(15, 2) // Running balance
  referenceType     String?          @map("reference_type") @db.VarChar(50) // 'pay_order', 'payment', 'receipt', 'return'
  referenceId       Int?             @map("reference_id")
  referenceNumber   String?          @map("reference_number") @db.VarChar(100)
  description       String?          @db.Text

  // Link to journal entry (for double-entry accounting)
  journalEntryId    Int?             @map("journal_entry_id")
  journalLineId     Int?             @map("journal_line_id")

  createdBy         Int?             @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")

  yarnVendor        YarnVendor?      @relation(fields: [yarnVendorId], references: [id])
  dyeingVendor      DyeingVendor?    @relation(fields: [dyeingVendorId], references: [id])
  generalSupplier   GeneralSupplier? @relation(fields: [generalSupplierId], references: [id])

  @@index([vendorType])
  @@index([yarnVendorId])
  @@index([dyeingVendorId])
  @@index([generalSupplierId])
  @@index([entryDate])
  @@index([entryType])
  @@index([journalEntryId])
  @@map("vendor_ledger_entries")
  @@schema("tenant_template")
}

// --- MATERIAL RECEIPTS (Track goods received from vendors) ---

model MaterialReceipt {
  id                Int                 @id @default(autoincrement())
  receiptNumber     String              @unique @map("receipt_number") @db.VarChar(50)
  vendorType        VendorType          @map("vendor_type")
  yarnVendorId      Int?                @map("yarn_vendor_id")
  dyeingVendorId    Int?                @map("dyeing_vendor_id")
  generalSupplierId Int?                @map("general_supplier_id")
  receiptDate       DateTime            @map("receipt_date") @db.Date
  receiptType       MaterialReceiptType @map("receipt_type")
  invoiceNumber     String?             @map("invoice_number") @db.VarChar(100)
  gatePassNumber    String?             @map("gate_pass_number") @db.VarChar(100)
  vehicleNumber     String?             @map("vehicle_number") @db.VarChar(50)
  payOrderId        Int?                @map("pay_order_id") // Link to PayOrder if applicable

  // Quantity summary
  orderedQty        Decimal?            @map("ordered_qty") @db.Decimal(12, 3)
  receivedQty       Decimal             @map("received_qty") @db.Decimal(12, 3)
  acceptedQty       Decimal             @map("accepted_qty") @db.Decimal(12, 3)
  rejectedQty       Decimal             @default(0) @map("rejected_qty") @db.Decimal(12, 3)
  unit              String              @default("KG") @db.VarChar(20)

  // Financial summary
  ratePerUnit       Decimal?            @map("rate_per_unit") @db.Decimal(12, 2)
  grossAmount       Decimal             @map("gross_amount") @db.Decimal(15, 2)
  discountAmount    Decimal             @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxAmount         Decimal             @default(0) @map("tax_amount") @db.Decimal(15, 2)
  netAmount         Decimal             @map("net_amount") @db.Decimal(15, 2)

  // Quality inspection
  qualityStatus     QualityStatus       @default(PENDING_INSPECTION) @map("quality_status")
  qualityCheckedBy  Int?                @map("quality_checked_by")
  qualityCheckedAt  DateTime?           @map("quality_checked_at")
  qualityNotes      String?             @map("quality_notes") @db.Text

  // Issue tracking
  hasIssue          Boolean             @default(false) @map("has_issue")
  issueType         MaterialIssueType?  @map("issue_type")
  issueDescription  String?             @map("issue_description") @db.Text

  notes             String?             @db.Text
  createdBy         Int?                @map("created_by")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  yarnVendor        YarnVendor?         @relation(fields: [yarnVendorId], references: [id])
  dyeingVendor      DyeingVendor?       @relation(fields: [dyeingVendorId], references: [id])
  generalSupplier   GeneralSupplier?    @relation(fields: [generalSupplierId], references: [id])
  items             MaterialReceiptItem[]
  returns           MaterialReturn[]

  @@index([vendorType])
  @@index([yarnVendorId])
  @@index([dyeingVendorId])
  @@index([generalSupplierId])
  @@index([receiptDate])
  @@index([qualityStatus])
  @@map("material_receipts")
  @@schema("tenant_template")
}

model MaterialReceiptItem {
  id              Int             @id @default(autoincrement())
  receiptId       Int             @map("receipt_id")
  productId       Int?            @map("product_id") // Link to Product if applicable
  yarnTypeId      Int?            @map("yarn_type_id") // Link to YarnType if applicable
  itemDescription String          @map("item_description") @db.VarChar(255)
  orderedQty      Decimal?        @map("ordered_qty") @db.Decimal(12, 3)
  receivedQty     Decimal         @map("received_qty") @db.Decimal(12, 3)
  acceptedQty     Decimal         @map("accepted_qty") @db.Decimal(12, 3)
  rejectedQty     Decimal         @default(0) @map("rejected_qty") @db.Decimal(12, 3)
  unit            String          @default("KG") @db.VarChar(20)
  ratePerUnit     Decimal         @map("rate_per_unit") @db.Decimal(12, 2)
  amount          Decimal         @db.Decimal(15, 2)
  qualityStatus   QualityStatus   @default(PENDING_INSPECTION) @map("quality_status")
  qualityNotes    String?         @map("quality_notes") @db.Text
  createdAt       DateTime        @default(now()) @map("created_at")

  receipt         MaterialReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([productId])
  @@index([yarnTypeId])
  @@map("material_receipt_items")
  @@schema("tenant_template")
}

// --- MATERIAL RETURNS (Track returns to vendors with replacement workflow) ---

model MaterialReturn {
  id                    Int               @id @default(autoincrement())
  returnNumber          String            @unique @map("return_number") @db.VarChar(50)
  vendorType            VendorType        @map("vendor_type")
  yarnVendorId          Int?              @map("yarn_vendor_id")
  dyeingVendorId        Int?              @map("dyeing_vendor_id")
  generalSupplierId     Int?              @map("general_supplier_id")
  materialReceiptId     Int?              @map("material_receipt_id") // Original receipt being returned
  returnDate            DateTime          @map("return_date") @db.Date
  returnChallanNumber   String?           @map("return_challan_number") @db.VarChar(100)

  // Issue details
  issueType             MaterialIssueType @map("issue_type")
  issueDescription      String?           @map("issue_description") @db.Text

  // Quantity and value
  returnedQuantity      Decimal           @map("returned_quantity") @db.Decimal(12, 3)
  unit                  String            @default("KG") @db.VarChar(20)
  returnValue           Decimal           @map("return_value") @db.Decimal(15, 2)

  // Replacement workflow
  replacementStatus     ReplacementStatus @default(REPORTED) @map("replacement_status")
  replacementQuantity   Decimal?          @map("replacement_quantity") @db.Decimal(12, 3)
  replacementDate       DateTime?         @map("replacement_date") @db.Date
  replacementReceiptId  Int?              @map("replacement_receipt_id") // Link to new receipt

  // Credit handling (if no replacement)
  creditAmount          Decimal?          @map("credit_amount") @db.Decimal(15, 2)
  creditDate            DateTime?         @map("credit_date") @db.Date
  creditNoteNumber      String?           @map("credit_note_number") @db.VarChar(100)

  // Resolution
  resolvedAt            DateTime?         @map("resolved_at")
  resolvedBy            Int?              @map("resolved_by")
  resolutionNotes       String?           @map("resolution_notes") @db.Text

  notes                 String?           @db.Text
  createdBy             Int?              @map("created_by")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  yarnVendor            YarnVendor?       @relation(fields: [yarnVendorId], references: [id])
  dyeingVendor          DyeingVendor?     @relation(fields: [dyeingVendorId], references: [id])
  generalSupplier       GeneralSupplier?  @relation(fields: [generalSupplierId], references: [id])
  materialReceipt       MaterialReceipt?  @relation(fields: [materialReceiptId], references: [id])

  @@index([vendorType])
  @@index([yarnVendorId])
  @@index([dyeingVendorId])
  @@index([generalSupplierId])
  @@index([returnDate])
  @@index([replacementStatus])
  @@map("material_returns")
  @@schema("tenant_template")
}

// --- CHEQUE MANAGEMENT (Full lifecycle tracking) ---

model Cheque {
  id                  Int                   @id @default(autoincrement())
  chequeNumber        String                @map("cheque_number") @db.VarChar(50)
  chequeType          ChequeType            @map("cheque_type") // ISSUED (we give) or RECEIVED (we get)

  // Entity references (one will be set based on cheque type and entity)
  customerId          Int?                  @map("customer_id")
  yarnVendorId        Int?                  @map("yarn_vendor_id")
  dyeingVendorId      Int?                  @map("dyeing_vendor_id")
  generalSupplierId   Int?                  @map("general_supplier_id")

  // Bank details
  bankName            String                @map("bank_name") @db.VarChar(100)
  branchName          String?               @map("branch_name") @db.VarChar(100)
  accountNumber       String?               @map("account_number") @db.VarChar(50)

  // Amount
  amount              Decimal               @db.Decimal(15, 2)

  // Dates
  chequeDate          DateTime              @map("cheque_date") @db.Date // Date on cheque
  receivedDate        DateTime?             @map("received_date") @db.Date // When we received it
  depositDate         DateTime?             @map("deposit_date") @db.Date // When deposited in bank
  clearanceDate       DateTime?             @map("clearance_date") @db.Date // When cleared
  bouncedDate         DateTime?             @map("bounced_date") @db.Date // If bounced

  // Status
  status              ChequeStatus          @default(PENDING)
  bounceReason        String?               @map("bounce_reason") @db.Text
  bounceCharges       Decimal?              @map("bounce_charges") @db.Decimal(10, 2)
  bounceCount         Int                   @default(0) @map("bounce_count")

  // Replacement tracking
  replacedByChequeId  Int?                  @unique @map("replaced_by_cheque_id")
  originalChequeId    Int?                  @map("original_cheque_id") // If this is a replacement cheque

  // Link to payments
  customerPaymentId   Int?                  @map("customer_payment_id")
  vendorPaymentId     Int?                  @map("vendor_payment_id")

  notes               String?               @db.Text
  createdBy           Int?                  @map("created_by")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  customer            Customer?             @relation(fields: [customerId], references: [id])
  yarnVendor          YarnVendor?           @relation(fields: [yarnVendorId], references: [id])
  dyeingVendor        DyeingVendor?         @relation(fields: [dyeingVendorId], references: [id])
  generalSupplier     GeneralSupplier?      @relation(fields: [generalSupplierId], references: [id])
  customerPayment     CustomerPayment?      @relation(fields: [customerPaymentId], references: [id])
  vendorPayment       VendorPayment?        @relation(fields: [vendorPaymentId], references: [id])
  replacedBy          Cheque?               @relation("ChequeReplacement", fields: [replacedByChequeId], references: [id])
  replaces            Cheque?               @relation("ChequeReplacement")
  statusHistory       ChequeStatusHistory[]

  @@index([chequeType])
  @@index([customerId])
  @@index([yarnVendorId])
  @@index([dyeingVendorId])
  @@index([generalSupplierId])
  @@index([status])
  @@index([chequeDate])
  @@index([depositDate])
  @@map("cheques")
  @@schema("tenant_template")
}

model ChequeStatusHistory {
  id          Int          @id @default(autoincrement())
  chequeId    Int          @map("cheque_id")
  fromStatus  ChequeStatus? @map("from_status")
  toStatus    ChequeStatus @map("to_status")
  changedBy   Int?         @map("changed_by")
  reason      String?      @db.Text
  changedAt   DateTime     @default(now()) @map("changed_at")

  cheque      Cheque       @relation(fields: [chequeId], references: [id], onDelete: Cascade)

  @@index([chequeId])
  @@index([changedAt])
  @@map("cheque_status_history")
  @@schema("tenant_template")
}

// --- MATERIAL TRANSACTIONS (Customer sales/returns/samples) ---

model MaterialTransaction {
  id                Int                     @id @default(autoincrement())
  transactionNumber String                  @unique @map("transaction_number") @db.VarChar(50)
  customerId        Int                     @map("customer_id")
  transactionDate   DateTime                @map("transaction_date") @db.Date
  transactionType   MaterialTransactionType @map("transaction_type")
  referenceNumber   String?                 @map("reference_number") @db.VarChar(100) // Delivery Challan, Invoice, etc.

  // Financial summary
  subtotal          Decimal                 @db.Decimal(15, 2)
  discountAmount    Decimal                 @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxAmount         Decimal                 @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount       Decimal                 @map("total_amount") @db.Decimal(15, 2)

  // Delivery details
  deliveryAddress   String?                 @map("delivery_address") @db.Text
  vehicleNumber     String?                 @map("vehicle_number") @db.VarChar(50)

  // Links
  salesOrderId      Int?                    @map("sales_order_id")
  ledgerEntryId     Int?                    @map("ledger_entry_id") // Link to CustomerLedgerEntry

  notes             String?                 @db.Text
  createdBy         Int?                    @map("created_by")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  customer          Customer                @relation(fields: [customerId], references: [id])
  items             MaterialTransactionItem[]

  @@index([customerId])
  @@index([transactionDate])
  @@index([transactionType])
  @@index([salesOrderId])
  @@map("material_transactions")
  @@schema("tenant_template")
}

model MaterialTransactionItem {
  id              Int                 @id @default(autoincrement())
  transactionId   Int                 @map("transaction_id")
  rollId          Int?                @map("roll_id") // If linked to specific roll
  productId       Int?                @map("product_id") // If linked to product
  itemDescription String              @map("item_description") @db.VarChar(255)
  fabricType      String?             @map("fabric_type") @db.VarChar(100)
  color           String?             @db.VarChar(100)
  quantity        Decimal             @db.Decimal(12, 3)
  unit            String              @default("KG") @db.VarChar(20)
  ratePerUnit     Decimal             @map("rate_per_unit") @db.Decimal(12, 2)
  amount          Decimal             @db.Decimal(15, 2)
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")

  transaction     MaterialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([rollId])
  @@index([productId])
  @@map("material_transaction_items")
  @@schema("tenant_template")
}

model OutstandingBalance {
  id                  Int       @id @default(autoincrement())
  entityType          String    @map("entity_type") @db.VarChar(50) // 'customer', 'yarn_vendor', 'dyeing_vendor', 'general_supplier'
  entityId            Int       @map("entity_id")
  openingBalance      Decimal   @map("opening_balance") @db.Decimal(15, 2)
  totalDebit          Decimal   @map("total_debit") @db.Decimal(15, 2)
  totalCredit         Decimal   @map("total_credit") @db.Decimal(15, 2)
  currentBalance      Decimal   @map("current_balance") @db.Decimal(15, 2)
  lastTransactionAt   DateTime? @map("last_transaction_at")
  isOverdue           Boolean   @default(false) @map("is_overdue")
  overdueAmount       Decimal   @default(0) @map("overdue_amount") @db.Decimal(15, 2)
  overdueDays         Int       @default(0) @map("overdue_days")
  creditLimit         Decimal?  @map("credit_limit") @db.Decimal(15, 2)
  availableCredit     Decimal?  @map("available_credit") @db.Decimal(15, 2)
  pendingChequeAmount Decimal   @default(0) @map("pending_cheque_amount") @db.Decimal(15, 2)
  pendingChequeCount  Int       @default(0) @map("pending_cheque_count")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([isOverdue])
  @@map("outstanding_balances")
  @@schema("tenant_template")
}

// --- AGING SNAPSHOTS (Point-in-time aging analysis) ---

model AgingSnapshot {
  id                Int      @id @default(autoincrement())
  entityType        String   @map("entity_type") @db.VarChar(50) // 'customer', 'yarn_vendor', 'dyeing_vendor', 'general_supplier'
  entityId          Int      @map("entity_id")
  snapshotDate      DateTime @map("snapshot_date") @db.Date

  // Aging buckets
  currentAmount     Decimal  @default(0) @map("current_amount") @db.Decimal(15, 2) // Not yet due
  days1To30         Decimal  @default(0) @map("days_1_to_30") @db.Decimal(15, 2) // 1-30 days overdue
  days31To60        Decimal  @default(0) @map("days_31_to_60") @db.Decimal(15, 2) // 31-60 days overdue
  days61To90        Decimal  @default(0) @map("days_61_to_90") @db.Decimal(15, 2) // 61-90 days overdue
  daysOver90        Decimal  @default(0) @map("days_over_90") @db.Decimal(15, 2) // 90+ days overdue

  // Summary
  totalOutstanding  Decimal  @map("total_outstanding") @db.Decimal(15, 2)
  totalOverdue      Decimal  @default(0) @map("total_overdue") @db.Decimal(15, 2)
  creditLimit       Decimal? @map("credit_limit") @db.Decimal(15, 2)
  availableCredit   Decimal? @map("available_credit") @db.Decimal(15, 2)

  createdAt         DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([snapshotDate])
  @@map("aging_snapshots")
  @@schema("tenant_template")
}

// --- PRODUCTS MODULE ---

model Product {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(255)
  type            ProductType      @default(GOODS)  // FABRIC or GOODS
  articleNumber   String?          @unique @map("article_number") @db.VarChar(50)
  qrCode          String           @unique @map("qr_code") @db.VarChar(50)

  // Lookup Relations
  departmentId    Int?             @map("department_id")
  groupId         Int?             @map("group_id")
  materialId      Int?             @map("material_id")
  brandId         Int?             @map("brand_id")
  colorId         Int?             @map("color_id")
  fabricSizeId    Int?             @map("fabric_size_id")

  // Fabric/Production Relations
  machineId            Int?              @map("machine_id")
  gradeId              Int?              @map("grade_id")
  fabricTypeId         Int?              @map("fabric_type_id")
  fabricCompositionId  Int?              @map("fabric_composition_id")

  // Fabric Properties
  gsm           Decimal?  @db.Decimal(6, 2)  // Grams per square meter
  width         Decimal?  @db.Decimal(6, 2)  // Width value
  widthUnit     String?   @default("inch") @map("width_unit") @db.VarChar(10) // inch, cm
  isTube        Boolean   @default(false) @map("is_tube") // Tube fabric (Yes/No)

  // Fabric Master Data Reference (optional link to pre-defined fabric)
  fabricId      Int?      @map("fabric_id")

  // Approval Workflow
  approvalStatus    ProductApprovalStatus  @default(PENDING) @map("approval_status")
  approvedBy        Int?                   @map("approved_by")
  approvedAt        DateTime?              @map("approved_at")
  rejectionReason   String?                @map("rejection_reason") @db.Text
  createdBy         Int?                   @map("created_by")

  // Additional Info
  description     String?          @db.Text
  unitPrice       Decimal?         @map("unit_price") @db.Decimal(12, 2)
  currency        String           @default("PKR") @db.VarChar(3)

  // Stock (updated by Stock In/Out transactions)
  currentStock    Decimal          @default(0) @map("current_stock") @db.Decimal(12, 3)

  // Images (stored as array of URLs)
  images          String[]         @default([])

  // Status
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  department         Department?         @relation(fields: [departmentId], references: [id])
  group              Group?              @relation(fields: [groupId], references: [id])
  material           Material?           @relation(fields: [materialId], references: [id])
  brand              Brand?              @relation(fields: [brandId], references: [id])
  color              Color?              @relation(fields: [colorId], references: [id])
  fabricSize         FabricSize?         @relation(fields: [fabricSizeId], references: [id])
  machine            Machine?            @relation("ProductMachine", fields: [machineId], references: [id])
  grade              Grade?              @relation("ProductGrade", fields: [gradeId], references: [id])
  fabricType         FabricType?         @relation("ProductFabricType", fields: [fabricTypeId], references: [id])
  fabricComposition  FabricComposition?  @relation("ProductFabricComposition", fields: [fabricCompositionId], references: [id])
  fabric             Fabric?             @relation("ProductFabric", fields: [fabricId], references: [id])
  stockMovements     StockMovement[]

  @@index([departmentId])
  @@index([groupId])
  @@index([materialId])
  @@index([brandId])
  @@index([colorId])
  @@index([fabricSizeId])
  @@index([machineId])
  @@index([gradeId])
  @@index([fabricTypeId])
  @@index([fabricCompositionId])
  @@index([fabricId])
  @@index([approvalStatus])
  @@index([createdBy])
  @@map("products")
  @@schema("tenant_template")
}

model StockMovement {
  id              Int               @id @default(autoincrement())
  productId       Int               @map("product_id")
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  referenceNumber String?           @map("reference_number") @db.VarChar(50)
  sourceType      String?           @map("source_type") @db.VarChar(50)
  destinationType String?           @map("destination_type") @db.VarChar(50)
  notes           String?           @db.Text
  createdBy       Int?              @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")

  product         Product           @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
  @@schema("tenant_template")
}

enum StockMovementType {
  IN
  OUT

  @@schema("tenant_template")
}

enum ProductApprovalStatus {
  PENDING   // Awaiting Super Admin approval
  APPROVED  // Approved by Super Admin
  REJECTED  // Rejected by Super Admin

  @@schema("tenant_template")
}

enum ProductType {
  FABRIC    // Fabric products (sale-ready rolls) - requires fabricId
  GOODS     // Other products (finished goods, etc.)

  @@schema("tenant_template")
}

// --- SETTINGS ---

model TenantSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       Json
  category    String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("tenant_settings")
  @@schema("tenant_template")
}

// --- DEPARTMENTS ---

model Department {
  id             Int       @id @default(autoincrement())
  code           String    @unique @db.VarChar(50)  // Auto-generated: DEPT-001, DEPT-002, etc.
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  parentId       Int?      @map("parent_id")

  // Personnel Information
  managerName    String?   @map("manager_name") @db.VarChar(255)
  contactPerson  String?   @map("contact_person") @db.VarChar(255)
  employeeCount  Int?      @map("employee_count") @default(0)

  // Keep for future User linkage
  managerId      Int?      @map("manager_id")

  notes          String?   @db.Text
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdBy      Int?      @map("created_by")
  updatedBy      Int?      @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  parent         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DepartmentHierarchy")
  groups         Group[]
  fabrics        Fabric[]
  products       Product[]

  @@index([parentId])
  @@index([isActive])
  @@map("departments")
  @@schema("tenant_template")
}

// --- PRODUCT GROUPS ---

model ProductGroup {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  parentId    Int?      @map("parent_id")
  notes       String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdBy   Int?      @map("created_by")
  updatedBy   Int?      @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent      ProductGroup?  @relation("ProductGroupHierarchy", fields: [parentId], references: [id])
  children    ProductGroup[] @relation("ProductGroupHierarchy")

  @@index([parentId])
  @@index([isActive])
  @@map("product_groups")
  @@schema("tenant_template")
}

// --- BRANDS ---

model Brand {
  id                 Int       @id @default(autoincrement())
  code               String    @unique @db.VarChar(50)  // Auto-generated: BRD-001, BRD-002, etc.
  name               String    @db.VarChar(255)          // REQUIRED - only required field
  description        String?   @db.Text
  logoUrl            String?   @map("logo_url") @db.VarChar(500)
  website            String?   @db.VarChar(255)

  // Contact Information
  phone              String?   @db.VarChar(50)
  email              String?   @db.VarChar(255)
  fax                String?   @db.VarChar(50)
  contactPerson      String?   @map("contact_person") @db.VarChar(255)

  // Address Fields (International Standard)
  addressLine1       String?   @map("address_line_1") @db.VarChar(255)
  addressLine2       String?   @map("address_line_2") @db.VarChar(255)
  city               String?   @db.VarChar(100)
  stateProvince      String?   @map("state_province") @db.VarChar(100)
  postalCode         String?   @map("postal_code") @db.VarChar(20)
  country            String?   @db.VarChar(100)

  // Business Registration (International Standard)
  taxId              String?   @map("tax_id") @db.VarChar(50)
  registrationNumber String?   @map("registration_number") @db.VarChar(50)

  notes              String?   @db.Text
  isActive           Boolean   @default(true) @map("is_active")
  sortOrder          Int       @default(0) @map("sort_order")
  createdBy          Int?      @map("created_by")
  updatedBy          Int?      @map("updated_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  fabrics            Fabric[]
  products           Product[]

  @@index([isActive])
  @@map("brands")
  @@schema("tenant_template")
}

// --- UNITS OF MEASUREMENT (International Standards) ---

model Unit {
  id            Int       @id @default(autoincrement())
  code          String    @unique @db.VarChar(20)
  name          String    @db.VarChar(100)
  symbol        String    @db.VarChar(20)
  category      UnitCategory
  description   String?   @db.Text

  // Conversion to base unit within category
  baseUnit      String?   @map("base_unit") @db.VarChar(20)
  conversionFactor Decimal? @map("conversion_factor") @db.Decimal(20, 10)

  // International standard reference
  siUnit        Boolean   @default(false) @map("si_unit")
  isoCode       String?   @map("iso_code") @db.VarChar(20)

  notes         String?   @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdBy     Int?      @map("created_by")
  updatedBy     Int?      @map("updated_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations for Stock Management
  stockItemsPrimary    StockItem[]        @relation("PrimaryUnit")
  stockItemsSecondary  StockItem[]        @relation("SecondaryUnit")
  stockTransactions    StockTransaction[]

  @@index([category])
  @@index([isActive])
  @@map("units")
  @@schema("tenant_template")
}

enum UnitCategory {
  LENGTH
  MASS
  VOLUME
  AREA
  COUNT
  TIME
  TEMPERATURE
  OTHER

  @@schema("tenant_template")
}

// Fiber Origin Types (following ISO 2076 / ISO 6938 standards)
// FiberOrigin enum removed - Material now stores Yarn Specs instead of fiber types

// --- GENERAL SETTINGS MASTER DATA ---

// Group Master (groups belong to a department)
model Group {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)  // Auto-generated: GRP-001, GRP-002, etc.
  name         String    @db.VarChar(255)

  // Department relation (REQUIRED)
  departmentId Int       @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  description  String?   @db.Text
  notes        String?   @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  sortOrder    Int       @default(0) @map("sort_order")
  createdBy    Int?      @map("created_by")
  updatedBy    Int?      @map("updated_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  fabrics        Fabric[]
  products       Product[]

  // Unique group name within department
  @@unique([departmentId, name], name: "unique_group_name_per_department")
  @@index([departmentId])
  @@index([isActive])
  @@map("groups")
  @@schema("tenant_template")
}

// Material Master (Fabric Materials / Fiber Types following ISO 2076 & ISO 6938)
// Examples: Cotton (CO), Polyester (PES), Wool (WO), Elastane (EL)
// Material = Yarn Specification (Raw Material)
// Examples: "70/24/1 RW", "150/48/2 FD", "75/36/1 SD"
// Format: Count/Filaments/Ply + Type (RW=Raw White, FD=Full Dull, SD=Semi Dull, BR=Bright)
model Material {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)   // Auto-generated: MAT-001, MAT-002
  name        String    @db.VarChar(255)          // Yarn spec: "70/24/1 RW", "150/48/2 FD"

  // Quality grading
  grade       String?   @db.VarChar(20)           // Quality grade: AAA, AA, A, B, C
  gradeNumber String?   @map("grade_number") @db.VarChar(50)  // Internal grade code/number

  // Optional details
  description String?   @db.Text                  // Additional description
  notes       String?   @db.Text                  // Internal notes

  // Status & timestamps
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdBy   Int?      @map("created_by")
  updatedBy   Int?      @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  fabrics     Fabric[]
  products    Product[]

  @@index([isActive])
  @@index([grade])
  @@map("materials")
  @@schema("tenant_template")
}

// Fabric Master (with QR Code support for hardware scanners)
model Fabric {
  id            Int       @id @default(autoincrement())
  code          String    @unique @map("fabric_code") @db.VarChar(50) // Auto-generated: FAB000001, FAB000002
  name          String    @db.VarChar(255)
  qrPayload     String?   @unique @map("qr_payload") @db.VarChar(100) // Format: FABRIC|FAB000001
  qrGeneratedAt DateTime? @map("qr_generated_at")

  // Required Relations
  departmentId  Int       @map("department_id")
  department    Department @relation(fields: [departmentId], references: [id])
  groupId       Int       @map("group_id")
  group         Group     @relation(fields: [groupId], references: [id])

  // Optional Relations
  materialId    Int?      @map("material_id")
  material      Material? @relation(fields: [materialId], references: [id])
  brandId       Int?      @map("brand_id")
  brand         Brand?    @relation(fields: [brandId], references: [id])
  colorId       Int?      @map("color_id")
  color         Color?    @relation(fields: [colorId], references: [id])
  machineId     Int?      @map("machine_id")
  machine       Machine?  @relation(fields: [machineId], references: [id])
  gradeId       Int?      @map("grade_id")
  grade         Grade?    @relation("FabricGrade", fields: [gradeId], references: [id])

  // Fabric Type & Composition (master data relations)
  fabricTypeId        Int?              @map("fabric_type_id")
  fabricType          FabricType?       @relation(fields: [fabricTypeId], references: [id])
  fabricCompositionId Int?              @map("fabric_composition_id")
  fabricComposition   FabricComposition? @relation(fields: [fabricCompositionId], references: [id])

  // Fabric Properties (keeping legacy string fields for backward compatibility)
  type          String?   @db.VarChar(100) // DEPRECATED: Use fabricTypeId instead
  composition   String?   @db.VarChar(255) // DEPRECATED: Use fabricCompositionId instead
  gsm           Decimal?  @db.Decimal(6, 2) // Grams per square meter
  width         Decimal?  @db.Decimal(6, 2) // Width value
  widthUnit     String?   @default("inch") @map("width_unit") @db.VarChar(10) // inch, cm
  isTube        Boolean   @default(false) @map("is_tube") // Tube fabric (Yes/No)

  // Stock tracking
  currentStock  Decimal   @default(0) @map("current_stock") @db.Decimal(12, 3)

  description   String?   @db.Text
  notes         String?   @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdBy     Int?      @map("created_by")
  updatedBy     Int?      @map("updated_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([type])
  @@index([qrPayload])
  @@index([departmentId])
  @@index([groupId])
  @@index([materialId])
  @@index([brandId])
  @@index([colorId])
  @@index([machineId])
  @@index([gradeId])
  @@index([fabricTypeId])
  @@index([fabricCompositionId])

  // Reverse relation: Products linked to this Fabric
  products      Product[] @relation("ProductFabric")

  // Reverse relation: Rolls produced from this Fabric template
  rolls         Roll[]

  // Reverse relation: Stock movements for this Fabric
  stockMovements FabricStockMovement[]

  @@map("fabrics")
  @@schema("tenant_template")
}

// Fabric Stock Movement (tracks IN/OUT for Fabric inventory)
model FabricStockMovement {
  id              Int               @id @default(autoincrement())
  fabricId        Int               @map("fabric_id")
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  referenceNumber String?           @map("reference_number") @db.VarChar(50)
  sourceType      String?           @map("source_type") @db.VarChar(50)
  destinationType String?           @map("destination_type") @db.VarChar(50)
  notes           String?           @db.Text
  createdBy       Int?              @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")

  fabric          Fabric            @relation(fields: [fabricId], references: [id])

  @@index([fabricId])
  @@index([type])
  @@index([createdAt])
  @@map("fabric_stock_movements")
  @@schema("tenant_template")
}

// Fabric Type Master (Single Jersey, Double Jersey, Rib, etc.)
model FabricType {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)     // Auto-generated: FT-001, FT-002
  name         String    @db.VarChar(100)            // e.g., "Single Jersey", "Double Jersey"
  description  String?   @db.Text
  notes        String?   @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  sortOrder    Int       @default(0) @map("sort_order")
  createdBy    Int?      @map("created_by")
  updatedBy    Int?      @map("updated_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  fabrics      Fabric[]
  products     Product[]  @relation("ProductFabricType")

  @@index([isActive])
  @@map("fabric_types")
  @@schema("tenant_template")
}

// Fabric Composition Master (100% Cotton, 50/50 Cotton/Polyester, etc.)
model FabricComposition {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)     // Auto-generated: FC-001, FC-002
  name         String    @db.VarChar(255)            // e.g., "100% Cotton", "50/50 Cotton/Polyester"
  description  String?   @db.Text
