// --- WHATSAPP INTEGRATION ---

model WhatsAppContact {
  id            Int               @id @default(autoincrement())
  phoneNumber   String            @unique @map("phone_number") @db.VarChar(20)
  waId          String?           @map("wa_id") @db.VarChar(50)
  name          String?           @db.VarChar(255)
  isVerified    Boolean           @default(false) @map("is_verified")
  optedIn       Boolean           @default(true) @map("opted_in")
  linkedTo      String?           @map("linked_to") @db.VarChar(50) // 'customer', 'vendor', 'owner'
  linkedId      Int?              @map("linked_id")
  language      String            @default("en") @db.VarChar(5) // 'en', 'ur'
  lastMessageAt DateTime?         @map("last_message_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  messages      WhatsAppMessage[]

  @@index([linkedTo, linkedId])
  @@index([isVerified])
  @@map("whatsapp_contacts")
  @@schema("tenant_template")
}

model WhatsAppMessage {
  id            Int             @id @default(autoincrement())
  contactId     Int             @map("contact_id")
  direction     MessageDirection
  messageType   String          @map("message_type") @db.VarChar(20) // 'text', 'template', 'interactive', 'image'
  content       Json            @db.JsonB
  waMessageId   String?         @unique @map("wa_message_id") @db.VarChar(100)
  status        MessageStatus   @default(PENDING)
  templateName  String?         @map("template_name") @db.VarChar(100)
  errorMessage  String?         @map("error_message") @db.Text
  sentAt        DateTime?       @map("sent_at")
  deliveredAt   DateTime?       @map("delivered_at")
  readAt        DateTime?       @map("read_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  contact       WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([status])
  @@index([createdAt])
  @@map("whatsapp_messages")
  @@schema("tenant_template")
}

enum MessageDirection {
  INBOUND
  OUTBOUND

  @@schema("tenant_template")
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED

  @@schema("tenant_template")
}

model WhatsAppTemplate {
  id            Int       @id @default(autoincrement())
  name          String    @unique @db.VarChar(100)
  language      String    @default("en") @db.VarChar(5)
  category      String    @db.VarChar(50) // 'order_update', 'daily_report', 'payment_reminder', 'query_response'
  description   String?   @db.Text
  components    Json      @db.JsonB // Template structure for Meta API
  variables     String[]  @default([]) // List of variable names used in template
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("whatsapp_templates")
  @@schema("tenant_template")
}

model WhatsAppSettings {
  id                    Int       @id @default(autoincrement())
  isEnabled             Boolean   @default(false) @map("is_enabled")
  phoneNumberId         String?   @map("phone_number_id") @db.VarChar(50)
  businessAccountId     String?   @map("business_account_id") @db.VarChar(50)
  dailyReportEnabled    Boolean   @default(true) @map("daily_report_enabled")
  dailyReportTime       String    @default("08:00") @map("daily_report_time") @db.VarChar(5) // HH:mm format
  dailyReportRecipients String[]  @default([]) @map("daily_report_recipients") // Phone numbers
  orderNotifications    Boolean   @default(true) @map("order_notifications")
  paymentReminders      Boolean   @default(true) @map("payment_reminders")
  queryBotEnabled       Boolean   @default(true) @map("query_bot_enabled")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("whatsapp_settings")
  @@schema("tenant_template")
}

// ===========================================
// NEEDLE MANAGEMENT MODULE
// ===========================================

model NeedleType {
  id                 Int       @id @default(autoincrement())
  code               String    @unique @db.VarChar(20) // NL-0001
  name               String    @db.VarChar(100) // "Latch Needle 18G"
  needleKind         String    @map("needle_kind") @db.VarChar(50) // LATCH, COMPOUND, BEARDED
  gauge              Int // 18, 20, 22, 24, etc.
  length             Decimal?  @db.Decimal(5, 2) // mm
  material           String    @db.VarChar(50) // Steel, Stainless Steel
  brand              String?   @db.VarChar(100)
  supplierCode       String?   @map("supplier_code") @db.VarChar(50) // Supplier's item code

  // Pricing
  costPerNeedle      Decimal?  @map("cost_per_needle") @db.Decimal(10, 2)
  currency           String    @default("PKR") @db.VarChar(10)

  // Inventory thresholds
  minStockLevel      Int       @default(100) @map("min_stock_level")
  reorderPoint       Int       @default(200) @map("reorder_point")

  // Compatibility
  compatibleMachines String[]  @default([]) @map("compatible_machines") // ["CIRCULAR_KNITTING"]

  // Link to unified stock item
  stockItemId        Int?      @unique @map("stock_item_id")

  notes              String?   @db.Text
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  stockBatches       NeedleStockBatch[]
  machineAllocations NeedleMachineAllocation[]
  damageRecords      NeedleDamage[]

  @@index([code])
  @@index([gauge])
  @@map("needle_types")
  @@schema("tenant_template")
}

model NeedleStockBatch {
  id                Int       @id @default(autoincrement())
  batchNumber       String    @unique @map("batch_number") @db.VarChar(30) // NB-2024-0001
  needleTypeId      Int       @map("needle_type_id")

  // Quantities
  receivedQuantity  Int       @map("received_quantity") // Total received
  currentQuantity   Int       @map("current_quantity") // Available in stock
  allocatedQuantity Int       @default(0) @map("allocated_quantity") // Assigned to machines
  damagedQuantity   Int       @default(0) @map("damaged_quantity") // Broken/defective

  // Receipt info
  receivedDate      DateTime  @default(now()) @map("received_date")
  invoiceNumber     String?   @map("invoice_number") @db.VarChar(50)
  invoiceDate       DateTime? @map("invoice_date")
  unitCost          Decimal?  @map("unit_cost") @db.Decimal(10, 2)
  totalCost         Decimal?  @map("total_cost") @db.Decimal(12, 2)

  // Supplier info
  supplierId        Int?      @map("supplier_id")
  supplierName      String?   @map("supplier_name") @db.VarChar(200)

  // Collection tracking
  collectedBy       Int?      @map("collected_by") // TenantUser ID
  collectorName     String?   @map("collector_name") @db.VarChar(100) // Denormalized name
  collectionDate    DateTime? @map("collection_date")

  lotNumber         String?   @map("lot_number") @db.VarChar(50)
  notes             String?   @db.Text

  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  needleType        NeedleType @relation(fields: [needleTypeId], references: [id])
  allocations       NeedleMachineAllocation[]
  damages           NeedleDamage[]
  movements         NeedleStockMovement[]

  @@index([batchNumber])
  @@index([needleTypeId])
  @@index([receivedDate])
  @@map("needle_stock_batches")
  @@schema("tenant_template")
}

model NeedleStockMovement {
  id                Int       @id @default(autoincrement())
  batchId           Int       @map("batch_id")
  movementType      String    @map("movement_type") @db.VarChar(20) // IN, OUT, ADJUST, DAMAGE, RETURN
  quantity          Int // Positive for IN, negative for OUT

  // Reference
  referenceType     String?   @map("reference_type") @db.VarChar(50) // PURCHASE, ALLOCATION, DAMAGE, ADJUSTMENT
  referenceId       Int?      @map("reference_id") // Related record ID

  // Actor
  performedBy       Int       @map("performed_by") // TenantUser ID
  performerName     String    @map("performer_name") @db.VarChar(100) // Denormalized

  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relations
  batch             NeedleStockBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([movementType])
  @@index([createdAt])
  @@map("needle_stock_movements")
  @@schema("tenant_template")
}

model NeedleMachineAllocation {
  id                Int       @id @default(autoincrement())
  machineId         Int       @map("machine_id")
  needleTypeId      Int       @map("needle_type_id")
  batchId           Int?      @map("batch_id") // Source batch

  // Quantities
  installedQuantity Int       @map("installed_quantity") // Needles installed
  position          String?   @db.VarChar(50) // Cylinder, Dial, Feeder 1-4

  // Installation info
  installedAt       DateTime  @default(now()) @map("installed_at")
  installedBy       Int       @map("installed_by") // TenantUser ID
  installerName     String    @map("installer_name") @db.VarChar(100)

  // Removal info (null if still installed)
  removedAt         DateTime? @map("removed_at")
  removedBy         Int?      @map("removed_by")
  removerName       String?   @map("remover_name") @db.VarChar(100)
  removalReason     String?   @map("removal_reason") @db.VarChar(100) // REPLACEMENT, MAINTENANCE, DAMAGE

  // Status
  status            String    @default("INSTALLED") @db.VarChar(20) // INSTALLED, REMOVED

  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  machine           Machine   @relation(fields: [machineId], references: [id])
  needleType        NeedleType @relation(fields: [needleTypeId], references: [id])
  batch             NeedleStockBatch? @relation(fields: [batchId], references: [id])
  damages           NeedleDamage[]

  @@index([machineId])
  @@index([needleTypeId])
  @@index([status])
  @@map("needle_machine_allocations")
  @@schema("tenant_template")
}

model NeedleDamage {
  id                Int       @id @default(autoincrement())
  needleTypeId      Int       @map("needle_type_id")
  batchId           Int?      @map("batch_id")
  allocationId      Int?      @map("allocation_id") // If damaged while installed
  machineId         Int?      @map("machine_id") // Machine where damage occurred

  // Damage info
  damageDate        DateTime  @default(now()) @map("damage_date")
  damageType        String    @map("damage_type") @db.VarChar(50) // BROKEN, BENT, WORN, HOOK_DAMAGE, LATCH_DAMAGE
  damagedQuantity   Int       @map("damaged_quantity")

  // Cause
  cause             String?   @db.VarChar(100) // YARN_KNOT, METAL_FATIGUE, OPERATOR_ERROR, UNKNOWN
  description       String?   @db.Text

  // Reporter
  reportedBy        Int       @map("reported_by") // TenantUser ID
  reporterName      String    @map("reporter_name") @db.VarChar(100)

  // Resolution
  resolutionStatus  String    @default("PENDING") @map("resolution_status") @db.VarChar(20) // PENDING, REPLACED, WRITTEN_OFF
  replacedQuantity  Int?      @map("replaced_quantity")
  replacedAt        DateTime? @map("replaced_at")
  replacedBy        Int?      @map("replaced_by")
  replacerName      String?   @map("replacer_name") @db.VarChar(100)

  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  needleType        NeedleType @relation(fields: [needleTypeId], references: [id])
  batch             NeedleStockBatch? @relation(fields: [batchId], references: [id])
  allocation        NeedleMachineAllocation? @relation(fields: [allocationId], references: [id])

  @@index([needleTypeId])
  @@index([machineId])
  @@index([damageDate])
  @@index([damageType])
  @@map("needle_damages")
  @@schema("tenant_template")
}

// ===========================================
// UNIFIED STOCK MANAGEMENT MODULE
// ===========================================

model Warehouse {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(50)
  name            String           @db.VarChar(255)
  description     String?          @db.Text

  // Location details
  address         String?          @db.Text
  city            String?          @db.VarChar(100)

  // Hierarchy (for sub-locations/bins)
  parentId        Int?             @map("parent_id")
  locationType    LocationType     @default(WAREHOUSE) @map("location_type")

  // Configuration
  isDefault       Boolean          @default(false) @map("is_default")
  allowNegative   Boolean          @default(false) @map("allow_negative")

  // Status
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  parent            Warehouse?       @relation("WarehouseHierarchy", fields: [parentId], references: [id])
  children          Warehouse[]      @relation("WarehouseHierarchy")
  stockLevels       StockLevel[]
  transactionsFrom  StockTransaction[] @relation("SourceWarehouse")
  transactionsTo    StockTransaction[] @relation("DestinationWarehouse")

  @@index([parentId])
  @@index([locationType])
  @@map("warehouses")
  @@schema("tenant_template")
}

enum LocationType {
  WAREHOUSE      // Main warehouse
  ZONE           // Zone within warehouse
  RACK           // Rack/shelf
  BIN            // Specific bin/location
  PRODUCTION     // Production floor
  QUALITY        // Quality hold area
  QUARANTINE     // Quarantine area

  @@schema("tenant_template")
}

model StockCategory {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(50)
  name            String           @db.VarChar(255)
  description     String?          @db.Text
  parentId        Int?             @map("parent_id")

  // Default settings for items in this category
  defaultUnitId   Int?             @map("default_unit_id")
  trackBatches    Boolean          @default(false) @map("track_batches")

  // Status
  isActive        Boolean          @default(true) @map("is_active")
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  parent          StockCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        StockCategory[]  @relation("CategoryHierarchy")
  items           StockItem[]

  @@index([parentId])
  @@map("stock_categories")
  @@schema("tenant_template")
}

model StockItem {
  id                  Int                @id @default(autoincrement())
  code                String             @unique @db.VarChar(50)
  name                String             @db.VarChar(255)
  description         String?            @db.Text

  // Classification
  itemType            StockItemType      @default(GENERAL) @map("item_type")
  categoryId          Int?               @map("category_id")
  productGroupId      Int?               @map("product_group_id")
  brandId             Int?               @map("brand_id")

  // Units of Measurement
  primaryUnitId       Int                @map("primary_unit_id")
  secondaryUnitId     Int?               @map("secondary_unit_id")
  conversionFactor    Decimal?           @map("conversion_factor") @db.Decimal(20, 10)

  // Tracking options
  trackBatches        Boolean            @default(false) @map("track_batches")
  trackSerials        Boolean            @default(false) @map("track_serials")
  trackExpiry         Boolean            @default(false) @map("track_expiry")

  // Stock configuration
  minStockLevel       Decimal?           @map("min_stock_level") @db.Decimal(12, 3)
  reorderPoint        Decimal?           @map("reorder_point") @db.Decimal(12, 3)
  reorderQuantity     Decimal?           @map("reorder_quantity") @db.Decimal(12, 3)
  maxStockLevel       Decimal?           @map("max_stock_level") @db.Decimal(12, 3)

  // Valuation
  valuationMethod     ValuationMethod    @default(WEIGHTED_AVERAGE) @map("valuation_method")
  standardCost        Decimal?           @map("standard_cost") @db.Decimal(15, 4)
  lastPurchaseCost    Decimal?           @map("last_purchase_cost") @db.Decimal(15, 4)
  averageCost         Decimal?           @map("average_cost") @db.Decimal(15, 4)
  currency            String             @default("PKR") @db.VarChar(3)

  // Industry-specific attributes (JSON for flexibility)
  attributes          Json?              @db.JsonB

  // Images and documents
  images              String[]           @default([])

  // Module association (for industry-specific items)
  moduleCode          String?            @map("module_code") @db.VarChar(50)  // 'YARN', 'NEEDLE', etc.

  // Status
  isActive            Boolean            @default(true) @map("is_active")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  // Relations
  category            StockCategory?     @relation(fields: [categoryId], references: [id])
  primaryUnit         Unit               @relation("PrimaryUnit", fields: [primaryUnitId], references: [id])
  secondaryUnit       Unit?              @relation("SecondaryUnit", fields: [secondaryUnitId], references: [id])
  stockLevels         StockLevel[]
  transactions        StockTransaction[]
  batches             StockBatch[]
  alerts              StockAlert[]

  @@index([code])
  @@index([itemType])
  @@index([categoryId])
  @@index([moduleCode])
  @@map("stock_items")
  @@schema("tenant_template")
}

enum StockItemType {
  GENERAL         // Generic products
  RAW_MATERIAL    // Materials for production
  FINISHED_GOODS  // Completed products
  CONSUMABLE      // Items consumed in production
  SPARE_PART      // Machine parts
  PACKAGING       // Packaging materials

  @@schema("tenant_template")
}

enum ValuationMethod {
  FIFO              // First In First Out
  LIFO              // Last In First Out
  WEIGHTED_AVERAGE  // Weighted Average Cost
  STANDARD_COST     // Fixed standard cost

  @@schema("tenant_template")
}

model StockLevel {
  id               Int          @id @default(autoincrement())
  itemId           Int          @map("item_id")
  warehouseId      Int          @map("warehouse_id")

  // Quantities
  quantityOnHand   Decimal      @default(0) @map("quantity_on_hand") @db.Decimal(12, 3)
  quantityReserved Decimal      @default(0) @map("quantity_reserved") @db.Decimal(12, 3)
  quantityAvailable Decimal     @default(0) @map("quantity_available") @db.Decimal(12, 3)
  quantityOnOrder  Decimal      @default(0) @map("quantity_on_order") @db.Decimal(12, 3)

  // Valuation
  totalValue       Decimal      @default(0) @map("total_value") @db.Decimal(15, 2)
  averageCost      Decimal?     @map("average_cost") @db.Decimal(15, 4)

  // Timestamps
  lastMovementAt   DateTime?    @map("last_movement_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  item             StockItem    @relation(fields: [itemId], references: [id])
  warehouse        Warehouse    @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
  @@index([itemId])
  @@index([warehouseId])
  @@map("stock_levels")
  @@schema("tenant_template")
}

model StockBatch {
  id                Int               @id @default(autoincrement())
  batchNumber       String            @unique @map("batch_number") @db.VarChar(100)
  itemId            Int               @map("item_id")

  // Batch details
  manufacturingDate DateTime?         @map("manufacturing_date") @db.Date
  expiryDate        DateTime?         @map("expiry_date") @db.Date
  lotNumber         String?           @map("lot_number") @db.VarChar(100)

  // Quantities
  initialQuantity   Decimal           @map("initial_quantity") @db.Decimal(12, 3)
  currentQuantity   Decimal           @map("current_quantity") @db.Decimal(12, 3)

  // Cost
  unitCost          Decimal?          @map("unit_cost") @db.Decimal(15, 4)
  totalCost         Decimal?          @map("total_cost") @db.Decimal(15, 2)

  // Source
  supplierId        Int?              @map("supplier_id")
  purchaseOrderRef  String?           @map("purchase_order_ref") @db.VarChar(100)

  // Custom attributes
  attributes        Json?             @db.JsonB
  notes             String?           @db.Text

  // Status
  status            BatchStatus       @default(ACTIVE)
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  item              StockItem         @relation(fields: [itemId], references: [id])
  transactions      StockTransaction[]

  @@index([itemId])
  @@index([batchNumber])
  @@index([expiryDate])
  @@map("stock_batches")
  @@schema("tenant_template")
}

enum BatchStatus {
  ACTIVE
  QUARANTINE
  EXPIRED
  DEPLETED

  @@schema("tenant_template")
}

model StockTransaction {
  id                  Int                   @id @default(autoincrement())
  transactionNumber   String                @unique @map("transaction_number") @db.VarChar(50)
  transactionDate     DateTime              @map("transaction_date") @db.Date
  transactionType     StockTransactionType  @map("transaction_type")

  // Item reference
  itemId              Int                   @map("item_id")
  batchId             Int?                  @map("batch_id")

  // Locations
  sourceWarehouseId   Int?                  @map("source_warehouse_id")
  destWarehouseId     Int?                  @map("dest_warehouse_id")

  // Quantities (always positive, type determines direction)
  quantity            Decimal               @db.Decimal(12, 3)
  unitId              Int                   @map("unit_id")

  // Cost/valuation
  unitCost            Decimal?              @map("unit_cost") @db.Decimal(15, 4)
  totalCost           Decimal?              @map("total_cost") @db.Decimal(15, 2)

  // Reference to source document
  referenceType       String?               @map("reference_type") @db.VarChar(50)
  referenceId         Int?                  @map("reference_id")
  referenceNumber     String?               @map("reference_number") @db.VarChar(100)

  // Additional info
  reason              String?               @db.VarChar(255)
  notes               String?               @db.Text

  // Audit
  createdBy           Int?                  @map("created_by")
  createdByName       String?               @map("created_by_name") @db.VarChar(100)
  approvedBy          Int?                  @map("approved_by")
  approvedAt          DateTime?             @map("approved_at")

  // Status
  status              TransactionStatus     @default(PENDING)
  isReversed          Boolean               @default(false) @map("is_reversed")
  reversalId          Int?                  @map("reversal_id")
  createdAt           DateTime              @default(now()) @map("created_at")

  // Relations
  item                StockItem             @relation(fields: [itemId], references: [id])
  batch               StockBatch?           @relation(fields: [batchId], references: [id])
  sourceWarehouse     Warehouse?            @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destWarehouse       Warehouse?            @relation("DestinationWarehouse", fields: [destWarehouseId], references: [id])
  unit                Unit                  @relation(fields: [unitId], references: [id])

  @@index([itemId])
  @@index([transactionDate])
  @@index([transactionType])
  @@index([referenceType, referenceId])
  @@map("stock_transactions")
  @@schema("tenant_template")
}

enum StockTransactionType {
  // Inward
  RECEIPT           // General receipt
  PURCHASE          // Purchase receipt
  RETURN_IN         // Customer return
  TRANSFER_IN       // Transfer from another location
  PRODUCTION_OUT    // Output from production
  ADJUSTMENT_IN     // Stock adjustment (increase)
  OPENING_STOCK     // Initial/opening stock

  // Outward
  ISSUE             // General issue
  SALE              // Sale/delivery
  RETURN_OUT        // Return to vendor
  TRANSFER_OUT      // Transfer to another location
  PRODUCTION_IN     // Input to production (consumption)
  ADJUSTMENT_OUT    // Stock adjustment (decrease)
  SCRAP             // Scrapped/written off
  SAMPLE            // Sample issue

  @@schema("tenant_template")
}

enum TransactionStatus {
  PENDING
  APPROVED
  COMPLETED
  REVERSED
  CANCELLED

  @@schema("tenant_template")
}

model StockAlert {
  id              Int              @id @default(autoincrement())
  itemId          Int              @map("item_id")
  warehouseId     Int?             @map("warehouse_id")
  alertType       StockAlertType   @map("alert_type")

  // Alert details
  currentLevel    Decimal          @map("current_level") @db.Decimal(12, 3)
  thresholdLevel  Decimal          @map("threshold_level") @db.Decimal(12, 3)

  // Status
  status          AlertStatus      @default(ACTIVE)
  acknowledgedBy  Int?             @map("acknowledged_by")
  acknowledgedAt  DateTime?        @map("acknowledged_at")
  resolvedAt      DateTime?        @map("resolved_at")

  // Timestamps
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  item            StockItem        @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@index([alertType])
  @@index([status])
  @@map("stock_alerts")
  @@schema("tenant_template")
}

enum StockAlertType {
  LOW_STOCK
  OUT_OF_STOCK
  REORDER_POINT
  OVERSTOCK
  EXPIRY_WARNING

  @@schema("tenant_template")
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  IGNORED

  @@schema("tenant_template")
}

model TenantModule {
  id              Int              @id @default(autoincrement())
  moduleCode      String           @unique @map("module_code") @db.VarChar(50)
  moduleName      String           @map("module_name") @db.VarChar(100)
  description     String?          @db.Text

  // Configuration
  isEnabled       Boolean          @default(true) @map("is_enabled")
  settings        Json?            @db.JsonB

  // Order in navigation
  sortOrder       Int              @default(0) @map("sort_order")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("tenant_modules")
  @@schema("tenant_template")
}

// ===========================================
// ACCOUNTING & FINANCIAL LEDGER MODULE
// ===========================================

model ChartOfAccount {
  id                Int                 @id @default(autoincrement())
  code              String              @unique @db.VarChar(20)
  name              String              @db.VarChar(255)
  nameUrdu          String?             @map("name_urdu") @db.VarChar(255)
  accountType       AccountType         @map("account_type")
  accountGroup      AccountGroup        @map("account_group")
  parentId          Int?                @map("parent_id")
  level             Int                 @default(1)
  isHeader          Boolean             @default(false) @map("is_header")
  isSystemAccount   Boolean             @default(false) @map("is_system_account")
  normalBalance     NormalBalance       @default(DEBIT) @map("normal_balance")

  // Currency
  currency          String              @default("PKR") @db.VarChar(3)

  // Control accounts
  isControlAccount  Boolean             @default(false) @map("is_control_account")
  controlledEntity  ControlledEntity?   @map("controlled_entity")

  // Balances (denormalized for performance)
  openingBalance    Decimal             @default(0) @map("opening_balance") @db.Decimal(15, 2)
  currentBalance    Decimal             @default(0) @map("current_balance") @db.Decimal(15, 2)

  // Status
  isActive          Boolean             @default(true) @map("is_active")
  isBankAccount     Boolean             @default(false) @map("is_bank_account")
  bankDetails       Json?               @map("bank_details") @db.JsonB

  // Metadata
  description       String?             @db.Text
  notes             String?             @db.Text
  tags              String[]            @default([])

  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  // Relations
  parent            ChartOfAccount?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children          ChartOfAccount[]    @relation("AccountHierarchy")
  journalLines      JournalLine[]
  budgets           AccountBudget[]
  generalLedger     GeneralLedger[]

  @@index([accountType])
  @@index([accountGroup])
  @@index([parentId])
  @@index([isActive])
  @@map("chart_of_accounts")
  @@schema("tenant_template")
}

enum AccountType {
  // Assets
  CASH
  BANK
  ACCOUNTS_RECEIVABLE
  INVENTORY
  FIXED_ASSET
  ACCUMULATED_DEPRECIATION
  OTHER_ASSET

  // Liabilities
  ACCOUNTS_PAYABLE
  SHORT_TERM_LIABILITY
  LONG_TERM_LIABILITY
  TAX_PAYABLE

  // Equity
  CAPITAL
  RETAINED_EARNINGS
  DRAWINGS

  // Revenue
  SALES_REVENUE
  OTHER_INCOME

  // Expenses
  COST_OF_GOODS_SOLD
  OPERATING_EXPENSE
  ADMINISTRATIVE_EXPENSE
  FINANCIAL_EXPENSE
  DEPRECIATION_EXPENSE
  TAX_EXPENSE

  @@schema("tenant_template")
}

enum AccountGroup {
  ASSETS
  LIABILITIES
  EQUITY
  REVENUE
  EXPENSE

  @@schema("tenant_template")
}

enum NormalBalance {
  DEBIT
  CREDIT

  @@schema("tenant_template")
}

enum ControlledEntity {
  CUSTOMER
  YARN_VENDOR
  DYEING_VENDOR
  GENERAL_SUPPLIER
  BANK
  INVENTORY

  @@schema("tenant_template")
}

model FiscalYear {
  id                Int               @id @default(autoincrement())
  code              String            @unique @db.VarChar(20)
  name              String            @db.VarChar(100)
  startDate         DateTime          @map("start_date") @db.Date
  endDate           DateTime          @map("end_date") @db.Date
  status            FiscalYearStatus  @default(OPEN)
  isCurrent         Boolean           @default(false) @map("is_current")

  // Closing
  closedAt          DateTime?         @map("closed_at")
  closedBy          Int?              @map("closed_by")
  closingEntryId    Int?              @map("closing_entry_id")

  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  periods           FiscalPeriod[]
  journals          JournalEntry[]
  budgets           AccountBudget[]
  generalLedger     GeneralLedger[]

  @@index([status])
  @@index([startDate, endDate])
  @@map("fiscal_years")
  @@schema("tenant_template")
}

enum FiscalYearStatus {
  DRAFT
  OPEN
  CLOSING
  CLOSED

  @@schema("tenant_template")
}

model FiscalPeriod {
  id                Int                 @id @default(autoincrement())
  fiscalYearId      Int                 @map("fiscal_year_id")
  periodNumber      Int                 @map("period_number")
  name              String              @db.VarChar(50)
  startDate         DateTime            @map("start_date") @db.Date
  endDate           DateTime            @map("end_date") @db.Date
  status            PeriodStatus        @default(OPEN)

  // Closing
  closedAt          DateTime?           @map("closed_at")
  closedBy          Int?                @map("closed_by")

  createdAt         DateTime            @default(now()) @map("created_at")

  // Relations
  fiscalYear        FiscalYear          @relation(fields: [fiscalYearId], references: [id])
  journals          JournalEntry[]
  generalLedger     GeneralLedger[]

  @@unique([fiscalYearId, periodNumber])
  @@index([status])
  @@map("fiscal_periods")
  @@schema("tenant_template")
}

enum PeriodStatus {
  FUTURE
  OPEN
  CLOSED

  @@schema("tenant_template")
}

model JournalEntry {
  id                Int               @id @default(autoincrement())
  entryNumber       String            @unique @map("entry_number") @db.VarChar(50)
  fiscalYearId      Int               @map("fiscal_year_id")
  fiscalPeriodId    Int               @map("fiscal_period_id")
  entryDate         DateTime          @map("entry_date") @db.Date
  entryType         JournalEntryType  @map("entry_type")

  // Amounts (for quick reference)
  totalDebit        Decimal           @map("total_debit") @db.Decimal(15, 2)
  totalCredit       Decimal           @map("total_credit") @db.Decimal(15, 2)

  // Reference/source
  sourceModule      SourceModule?     @map("source_module")
  sourceType        String?           @map("source_type") @db.VarChar(50)
  sourceId          Int?              @map("source_id")
  referenceNumber   String?           @map("reference_number") @db.VarChar(100)

  // Description
  narration         String?           @db.Text
  description       String?           @db.Text

  // Status & workflow
  status            JournalStatus     @default(DRAFT)
  isAutoGenerated   Boolean           @default(false) @map("is_auto_generated")
  isReversing       Boolean           @default(false) @map("is_reversing")
  reversedEntryId   Int?              @map("reversed_entry_id")
  reversingEntryId  Int?              @map("reversing_entry_id")

  // Approval
  createdBy         Int               @map("created_by")
  approvedBy        Int?              @map("approved_by")
  approvedAt        DateTime?         @map("approved_at")
  rejectedBy        Int?              @map("rejected_by")
  rejectedAt        DateTime?         @map("rejected_at")
  rejectionReason   String?           @map("rejection_reason") @db.Text

  // Posting
  postedAt          DateTime?         @map("posted_at")
  postedBy          Int?              @map("posted_by")

  // Attachments
  attachments       Json?             @db.JsonB

  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  fiscalYear        FiscalYear        @relation(fields: [fiscalYearId], references: [id])
  fiscalPeriod      FiscalPeriod      @relation(fields: [fiscalPeriodId], references: [id])
  lines             JournalLine[]
  generalLedger     GeneralLedger[]

  @@index([entryDate])
  @@index([status])
  @@index([sourceModule, sourceId])
  @@index([fiscalYearId])
  @@index([fiscalPeriodId])
  @@map("journal_entries")
  @@schema("tenant_template")
}

enum JournalEntryType {
  GENERAL           // Manual journal
  SALES             // Auto from sales
  PURCHASE          // Auto from purchases
  RECEIPT           // Cash/bank receipt
  PAYMENT           // Cash/bank payment
  ADJUSTMENT        // Adjusting entries
  CLOSING           // Period/year end closing
  OPENING           // Opening balances
  REVERSING         // Reversing entries

  @@schema("tenant_template")
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REJECTED
  VOIDED

  @@schema("tenant_template")
}

enum SourceModule {
  MANUAL
  SALES
  PURCHASES
  INVENTORY
  PAYROLL
  FIXED_ASSETS
  BANK
  RECEIVABLES
  PAYABLES

  @@schema("tenant_template")
}

model JournalLine {
  id                Int             @id @default(autoincrement())
  journalEntryId    Int             @map("journal_entry_id")
  lineNumber        Int             @map("line_number")
  accountId         Int             @map("account_id")

  // Amounts
  debitAmount       Decimal         @default(0) @map("debit_amount") @db.Decimal(15, 2)
  creditAmount      Decimal         @default(0) @map("credit_amount") @db.Decimal(15, 2)

  // Multi-currency support
  currency          String          @default("PKR") @db.VarChar(3)
  exchangeRate      Decimal         @default(1) @map("exchange_rate") @db.Decimal(12, 6)
  baseCurrencyDebit  Decimal        @default(0) @map("base_currency_debit") @db.Decimal(15, 2)
  baseCurrencyCredit Decimal        @default(0) @map("base_currency_credit") @db.Decimal(15, 2)

  // Sub-ledger reference (for control accounts)
  entityType        String?         @map("entity_type") @db.VarChar(50)
  entityId          Int?            @map("entity_id")

  // Description
  description       String?         @db.VarChar(500)

  // Cost center / department
  departmentId      Int?            @map("department_id")
  costCenterId      Int?            @map("cost_center_id")
  projectId         Int?            @map("project_id")

  createdAt         DateTime        @default(now()) @map("created_at")

  // Relations
  journalEntry      JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account           ChartOfAccount  @relation(fields: [accountId], references: [id])
  generalLedger     GeneralLedger[]

  @@index([journalEntryId])
  @@index([accountId])
  @@index([entityType, entityId])
  @@map("journal_lines")
  @@schema("tenant_template")
}

model GeneralLedger {
  id                Int             @id @default(autoincrement())
  accountId         Int             @map("account_id")
  fiscalYearId      Int             @map("fiscal_year_id")
  fiscalPeriodId    Int             @map("fiscal_period_id")
  entryDate         DateTime        @map("entry_date") @db.Date
  journalEntryId    Int             @map("journal_entry_id")
  journalLineId     Int             @map("journal_line_id")

  // Amounts
  debitAmount       Decimal         @default(0) @map("debit_amount") @db.Decimal(15, 2)
  creditAmount      Decimal         @default(0) @map("credit_amount") @db.Decimal(15, 2)
  runningBalance    Decimal         @map("running_balance") @db.Decimal(15, 2)

  // Reference
  referenceNumber   String?         @map("reference_number") @db.VarChar(100)
  description       String?         @db.VarChar(500)

  // Sub-ledger tracking
  entityType        String?         @map("entity_type") @db.VarChar(50)
  entityId          Int?            @map("entity_id")

  createdAt         DateTime        @default(now()) @map("created_at")

  // Relations
  account           ChartOfAccount  @relation(fields: [accountId], references: [id])
  fiscalYear        FiscalYear      @relation(fields: [fiscalYearId], references: [id])
  fiscalPeriod      FiscalPeriod    @relation(fields: [fiscalPeriodId], references: [id])
  journalEntry      JournalEntry    @relation(fields: [journalEntryId], references: [id])
  journalLine       JournalLine     @relation(fields: [journalLineId], references: [id])

  @@index([accountId, entryDate])
  @@index([fiscalYearId])
  @@index([fiscalPeriodId])
  @@index([journalEntryId])
  @@index([entityType, entityId])
  @@map("general_ledger")
  @@schema("tenant_template")
}

model BankReconciliation {
  id                  Int                       @id @default(autoincrement())
  accountId           Int                       @map("account_id")
  statementDate       DateTime                  @map("statement_date") @db.Date
  statementNumber     String?                   @map("statement_number") @db.VarChar(50)

  // Opening balance
  openingBookBalance  Decimal                   @map("opening_book_balance") @db.Decimal(15, 2)
  openingBankBalance  Decimal                   @map("opening_bank_balance") @db.Decimal(15, 2)

  // Closing balance
  closingBookBalance  Decimal                   @map("closing_book_balance") @db.Decimal(15, 2)
  closingBankBalance  Decimal                   @map("closing_bank_balance") @db.Decimal(15, 2)

  // Reconciliation
  reconciledAmount    Decimal                   @default(0) @map("reconciled_amount") @db.Decimal(15, 2)
  unreconciledDiff    Decimal                   @default(0) @map("unreconciled_diff") @db.Decimal(15, 2)

  status              ReconciliationStatus      @default(IN_PROGRESS)
  reconciledAt        DateTime?                 @map("reconciled_at")
  reconciledBy        Int?                      @map("reconciled_by")

  notes               String?                   @db.Text

  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  // Relations
  items               BankReconciliationItem[]

  @@index([accountId])
  @@index([statementDate])
  @@map("bank_reconciliations")
  @@schema("tenant_template")
}

enum ReconciliationStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@schema("tenant_template")
}

model BankReconciliationItem {
  id                  Int                   @id @default(autoincrement())
  reconciliationId    Int                   @map("reconciliation_id")
  generalLedgerId     Int?                  @map("general_ledger_id")

  // Bank statement data
  statementDate       DateTime              @map("statement_date") @db.Date
  statementRef        String?               @map("statement_ref") @db.VarChar(100)
  statementAmount     Decimal               @map("statement_amount") @db.Decimal(15, 2)
  statementDescription String?              @map("statement_description") @db.VarChar(500)

  // Matching
  isMatched           Boolean               @default(false) @map("is_matched")
  matchedAt           DateTime?             @map("matched_at")

  // For outstanding items
  isOutstanding       Boolean               @default(false) @map("is_outstanding")
  outstandingType     OutstandingType?      @map("outstanding_type")

  createdAt           DateTime              @default(now()) @map("created_at")

  reconciliation      BankReconciliation    @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([reconciliationId])
  @@map("bank_reconciliation_items")
  @@schema("tenant_template")
}

enum OutstandingType {
  OUTSTANDING_CHEQUE
  DEPOSIT_IN_TRANSIT
  BANK_CHARGE
  BANK_INTEREST
  OTHER

  @@schema("tenant_template")
}

model AccountBudget {
  id                Int             @id @default(autoincrement())
  accountId         Int             @map("account_id")
  fiscalYearId      Int             @map("fiscal_year_id")
  periodNumber      Int?            @map("period_number")

  budgetAmount      Decimal         @map("budget_amount") @db.Decimal(15, 2)
  actualAmount      Decimal         @default(0) @map("actual_amount") @db.Decimal(15, 2)
  varianceAmount    Decimal         @default(0) @map("variance_amount") @db.Decimal(15, 2)
  variancePercent   Decimal         @default(0) @map("variance_percent") @db.Decimal(7, 2)

  notes             String?         @db.Text

  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  account           ChartOfAccount  @relation(fields: [accountId], references: [id])
  fiscalYear        FiscalYear      @relation(fields: [fiscalYearId], references: [id])

  @@unique([accountId, fiscalYearId, periodNumber])
  @@map("account_budgets")
  @@schema("tenant_template")
}

model AccountingSettings {
  id                      Int       @id @default(autoincrement())

  // Base currency
  baseCurrency            String    @default("PKR") @map("base_currency") @db.VarChar(3)

  // Fiscal year settings (July for Pakistan)
  fiscalYearStartMonth    Int       @default(7) @map("fiscal_year_start_month")
  fiscalYearStartDay      Int       @default(1) @map("fiscal_year_start_day")

  // Accounting method
  accountingMethod        String    @default("ACCRUAL") @map("accounting_method") @db.VarChar(20)

  // Default accounts (FK to ChartOfAccount)
  defaultCashAccountId    Int?      @map("default_cash_account_id")
  defaultBankAccountId    Int?      @map("default_bank_account_id")
  defaultReceivablesId    Int?      @map("default_receivables_id")
  defaultPayablesId       Int?      @map("default_payables_id")
  defaultSalesRevenueId   Int?      @map("default_sales_revenue_id")
  defaultCOGSId           Int?      @map("default_cogs_id")
  defaultInventoryId      Int?      @map("default_inventory_id")
  retainedEarningsId      Int?      @map("retained_earnings_id")

  // Tax settings (Pakistan GST 17%)
  defaultTaxAccountId     Int?      @map("default_tax_account_id")
  salesTaxRate            Decimal   @default(17) @map("sales_tax_rate") @db.Decimal(5, 2)

  // Auto-posting
  autoPostOnApproval      Boolean   @default(true) @map("auto_post_on_approval")
  requireApprovalThreshold Decimal? @map("require_approval_threshold") @db.Decimal(15, 2)

  // Number series
  journalPrefix           String    @default("JV") @map("journal_prefix") @db.VarChar(10)
  journalNextNumber       Int       @default(1) @map("journal_next_number")

  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("accounting_settings")
  @@schema("tenant_template")
}

model CurrencyExchangeRate {
  id                Int       @id @default(autoincrement())
  fromCurrency      String    @map("from_currency") @db.VarChar(3)
  toCurrency        String    @map("to_currency") @db.VarChar(3)
  effectiveDate     DateTime  @map("effective_date") @db.Date
  rate              Decimal   @db.Decimal(12, 6)
  source            String?   @db.VarChar(50)

  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([fromCurrency, toCurrency, effectiveDate])
  @@index([effectiveDate])
  @@map("currency_exchange_rates")
  @@schema("tenant_template")
}

// ==================== CHAT MODELS ====================

model ChatConversation {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  title         String?       @db.VarChar(255)
  language      String        @default("en") @db.VarChar(5)
  messageCount  Int           @default(0) @map("message_count")
  lastMessageAt DateTime      @map("last_message_at")
  isArchived    Boolean       @default(false) @map("is_archived")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  messages      ChatMessage[]

  @@index([userId])
  @@index([lastMessageAt])
  @@map("chat_conversations")
  @@schema("tenant_template")
}

model ChatMessage {
  id             Int              @id @default(autoincrement())
  conversationId Int              @map("conversation_id")
  role           ChatRole
  content        String           @db.Text
  contentUrdu    String?          @map("content_urdu") @db.Text
  intent         String?          @db.VarChar(100)
  tokensUsed     Int?             @map("tokens_used")
  modelUsed      String?          @map("model_used") @db.VarChar(50)
  latencyMs      Int?             @map("latency_ms")
  metadata       Json?            @db.JsonB
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
  @@schema("tenant_template")
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM

  @@schema("tenant_template")
}
