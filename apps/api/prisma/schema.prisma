// Mughal Grace - Knitting Factory SaaS
// Multi-tenant PostgreSQL Schema with Schema-per-tenant isolation

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "tenant_template"]
}

// ==================== PUBLIC SCHEMA (Multi-Tenant Admin) ====================

model Tenant {
  id                 Int           @id @default(autoincrement())
  slug               String        @unique @db.VarChar(100)
  name               String        @db.VarChar(255)
  schemaName         String        @unique @map("schema_name") @db.VarChar(100)
  ownerName          String        @map("owner_name") @db.VarChar(255)
  ownerEmail         String        @map("owner_email") @db.VarChar(255)
  ownerPhone         String?       @map("owner_phone") @db.VarChar(50)
  address            String?       @db.Text
  city               String?       @db.VarChar(100)
  totalMachines      Int           @default(0) @map("total_machines")
  factoryType        String        @default("knitting") @map("factory_type") @db.VarChar(50)
  plan               TenantPlan    @default(TRIAL)
  status             TenantStatus  @default(PENDING)
  trialEndsAt        DateTime?     @map("trial_ends_at")
  subscriptionEndsAt DateTime?     @map("subscription_ends_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")
  users              TenantUser[]

  @@map("tenants")
  @@schema("public")
}

enum TenantPlan {
  TRIAL
  BASIC
  PROFESSIONAL
  ENTERPRISE

  @@schema("public")
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED

  @@schema("public")
}

model TenantUser {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @map("tenant_id")
  email          String    @db.VarChar(255)
  username       String    @db.VarChar(100)
  hashedPassword String    @map("hashed_password") @db.VarChar(255)
  fullName       String?   @map("full_name") @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  role           UserRole  @default(OPERATOR)
  permissions    Json      @default("[]")
  isActive       Boolean   @default(true) @map("is_active")
  isVerified     Boolean   @default(false) @map("is_verified")
  lastLogin      DateTime? @map("last_login")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@map("tenant_users")
  @@schema("public")
}

enum UserRole {
  SUPER_ADMIN
  FACTORY_OWNER
  MANAGER
  SUPERVISOR
  OPERATOR
  ACCOUNTANT
  VIEWER

  @@schema("public")
}

model AuditLog {
  id         Int       @id @default(autoincrement())
  tenantId   Int?      @map("tenant_id")
  userId     Int?      @map("user_id")
  action     String    @db.VarChar(100)
  entityType String    @map("entity_type") @db.VarChar(100)
  entityId   Int?      @map("entity_id")
  oldValues  Json?     @map("old_values")
  newValues  Json?     @map("new_values")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
  @@schema("public")
}

// ==================== TENANT TEMPLATE SCHEMA ====================
// These models are copied to each tenant's schema on creation

// --- YARN INVENTORY MODULE ---

model YarnType {
  id                Int        @id @default(autoincrement())
  code              String     @unique @db.VarChar(50)
  name              String     @db.VarChar(255)
  description       String?    @db.Text

  // Core fields
  brandName         String     @default("") @map("brand_name") @db.VarChar(255)
  color             String     @default("") @db.VarChar(100)
  grade             String     @default("A") @db.VarChar(50)

  // Composition (JSON array of {fiberType, percentage})
  composition       Json?      @db.JsonB

  // Count/thickness
  countValue        Decimal?   @map("count_value") @db.Decimal(10, 2)
  countSystem       String?    @map("count_system") @db.VarChar(20) // NE, TEX, DENIER, NM

  // Pricing
  defaultPricePerKg Decimal?   @map("default_price_per_kg") @db.Decimal(12, 2)
  priceUnit         String     @default("KG") @map("price_unit") @db.VarChar(10)
  currency          String     @default("PKR") @db.VarChar(10)

  // Classification
  category          String?    @db.VarChar(100)
  tags              String[]   @default([])
  certifications    String[]   @default([])

  // Status & timestamps
  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  // Relations
  cones             YarnCone[]
  boxes             YarnBox[]
  payOrderItems     PayOrderItem[]
  ledgerEntries     YarnLedger[]
  outwards          YarnOutward[]
  blendItems        YarnTypeKnittingYarn[]

  @@map("yarn_types")
  @@schema("tenant_template")
}

// --- KNITTING YARN / BLEND MODULE ---

model KnittingYarn {
  id                Int        @id @default(autoincrement())
  code              String     @unique @db.VarChar(50)
  name              String     @db.VarChar(255)
  description       String?    @db.Text

  // Computed blend summary (auto-generated from yarnTypes)
  blendSummary      String?    @map("blend_summary") @db.VarChar(500)

  // Pricing (average of components)
  defaultPricePerKg Decimal?   @map("default_price_per_kg") @db.Decimal(12, 2)

  // Status & timestamps
  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  // Relations
  yarnTypes         YarnTypeKnittingYarn[]

  @@map("knitting_yarns")
  @@schema("tenant_template")
}

model YarnTypeKnittingYarn {
  id             Int          @id @default(autoincrement())
  knittingYarnId Int          @map("knitting_yarn_id")
  yarnTypeId     Int          @map("yarn_type_id")
  percentage     Decimal      @db.Decimal(5, 2) // e.g., 50.00 for 50%
  createdAt      DateTime     @default(now()) @map("created_at")

  knittingYarn   KnittingYarn @relation(fields: [knittingYarnId], references: [id], onDelete: Cascade)
  yarnType       YarnType     @relation(fields: [yarnTypeId], references: [id])

  @@unique([knittingYarnId, yarnTypeId])
  @@index([knittingYarnId])
  @@index([yarnTypeId])
  @@map("yarn_type_knitting_yarn")
  @@schema("tenant_template")
}

model YarnVendor {
  id               Int                 @id @default(autoincrement())
  code             String              @unique @db.VarChar(50)
  name             String              @db.VarChar(255)
  contactPerson    String?             @map("contact_person") @db.VarChar(255)
  phone            String?             @db.VarChar(50)
  email            String?             @db.VarChar(255)
  address          String?             @db.Text
  city             String?             @db.VarChar(100)
  creditLimit      Decimal?            @map("credit_limit") @db.Decimal(15, 2)
  paymentTerms     Int                 @default(30) @map("payment_terms")
  isActive         Boolean             @default(true) @map("is_active")
  rating           Int?
  notes            String?             @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  boxes              YarnBox[]
  payments           VendorPayment[]
  payOrders          PayOrder[]
  ledgerEntries      VendorLedgerEntry[]
  materialReceipts   MaterialReceipt[]
  materialReturns    MaterialReturn[]
  cheques            Cheque[]
  yarnLedgerEntries  YarnLedger[]

  @@map("yarn_vendors")
  @@schema("tenant_template")
}

// --- PAY ORDER MODULE (Yarn Purchase Orders) ---

model PayOrder {
  id                   Int             @id @default(autoincrement())
  orderNumber          String          @unique @map("order_number") @db.VarChar(50)
  vendorId             Int             @map("vendor_id")
  orderDate            DateTime        @map("order_date") @db.Date
  expectedDeliveryDate DateTime?       @map("expected_delivery_date") @db.Date
  totalQuantity        Decimal         @default(0) @map("total_quantity") @db.Decimal(12, 3)
  totalAmount          Decimal?        @map("total_amount") @db.Decimal(15, 2)
  status               PayOrderStatus  @default(DRAFT)
  terms                String?         @db.Text
  notes                String?         @db.Text

  // Workflow tracking
  createdBy            Int?            @map("created_by")
  approvedBy           Int?            @map("approved_by")
  approvedAt           DateTime?       @map("approved_at")
  sentAt               DateTime?       @map("sent_at")

  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  // Relations
  vendor               YarnVendor      @relation(fields: [vendorId], references: [id])
  items                PayOrderItem[]
  receivedBoxes        YarnBox[]

  @@index([vendorId])
  @@index([status])
  @@index([orderDate])
  @@map("pay_orders")
  @@schema("tenant_template")
}

enum PayOrderStatus {
  DRAFT
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED

  @@schema("tenant_template")
}

model PayOrderItem {
  id              Int      @id @default(autoincrement())
  payOrderId      Int      @map("pay_order_id")
  yarnTypeId      Int      @map("yarn_type_id")
  orderedQuantity Decimal  @map("ordered_quantity") @db.Decimal(12, 3)
  receivedQuantity Decimal @default(0) @map("received_quantity") @db.Decimal(12, 3)
  unit            String   @default("KG") @db.VarChar(20)
  pricePerUnit    Decimal? @map("price_per_unit") @db.Decimal(12, 2)
  amount          Decimal? @db.Decimal(15, 2)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  payOrder        PayOrder @relation(fields: [payOrderId], references: [id], onDelete: Cascade)
  yarnType        YarnType @relation(fields: [yarnTypeId], references: [id])

  @@index([payOrderId])
  @@index([yarnTypeId])
  @@map("pay_order_items")
  @@schema("tenant_template")
}

model YarnBox {
  id             Int        @id @default(autoincrement())
  boxNumber      String     @unique @map("box_number") @db.VarChar(50)
  vendorId       Int        @map("vendor_id")
  yarnTypeId     Int        @map("yarn_type_id")
  lotNumber      String?    @map("lot_number") @db.VarChar(100)
  grossWeight    Decimal    @map("gross_weight") @db.Decimal(10, 3)
  tareWeight     Decimal    @default(0) @map("tare_weight") @db.Decimal(10, 3)
  netWeight      Decimal    @map("net_weight") @db.Decimal(10, 3)
  pricePerKg     Decimal    @map("price_per_kg") @db.Decimal(12, 2)
  totalValue     Decimal    @map("total_value") @db.Decimal(15, 2)
  receivedAt     DateTime   @map("received_at")
  invoiceNumber  String?    @map("invoice_number") @db.VarChar(100)
  gatePassNumber String?    @map("gate_pass_number") @db.VarChar(100)
  payOrderId     Int?       @map("pay_order_id")
  status         BoxStatus  @default(IN_STOCK)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  vendor         YarnVendor    @relation(fields: [vendorId], references: [id])
  yarnType       YarnType      @relation(fields: [yarnTypeId], references: [id])
  payOrder       PayOrder?     @relation(fields: [payOrderId], references: [id])
  cones          YarnCone[]
  outwards       YarnOutward[]

  @@index([vendorId])
  @@index([yarnTypeId])
  @@index([payOrderId])
  @@index([status])
  @@index([receivedAt])
  @@map("yarn_boxes")
  @@schema("tenant_template")
}

enum BoxStatus {
  IN_STOCK
  PARTIALLY_USED
  EMPTY
  RETURNED

  @@schema("tenant_template")
}

model YarnCone {
  id                Int               @id @default(autoincrement())
  coneNumber        String            @unique @map("cone_number") @db.VarChar(50)
  boxId             Int               @map("box_id")
  yarnTypeId        Int               @map("yarn_type_id")
  initialWeight     Decimal           @map("initial_weight") @db.Decimal(10, 3)
  currentWeight     Decimal           @map("current_weight") @db.Decimal(10, 3)
  usedWeight        Decimal           @default(0) @map("used_weight") @db.Decimal(10, 3)
  status            ConeStatus        @default(AVAILABLE)
  assignedMachineId Int?              @map("assigned_machine_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  box               YarnBox           @relation(fields: [boxId], references: [id])
  yarnType          YarnType          @relation(fields: [yarnTypeId], references: [id])
  machine           Machine?          @relation(fields: [assignedMachineId], references: [id])
  consumptions      YarnConsumption[]

  @@index([boxId])
  @@index([yarnTypeId])
  @@index([status])
  @@map("yarn_cones")
  @@schema("tenant_template")
}

enum ConeStatus {
  AVAILABLE
  IN_USE
  EMPTY
  DEFECTIVE

  @@schema("tenant_template")
}

// --- MACHINE & PRODUCTION MODULE ---

model Machine {
  id                Int             @id @default(autoincrement())
  machineNumber     String          @unique @map("machine_number") @db.VarChar(50)
  name              String          @db.VarChar(255)
  brand             String?         @db.VarChar(100)
  model             String?         @db.VarChar(100)
  serialNumber      String?         @map("serial_number") @db.VarChar(100)
  machineType       MachineType     @map("machine_type")
  gauge             Int?
  diameter          Int?
  feeders           Int?
  location          String?         @db.VarChar(100)
  position          String?         @db.VarChar(50)
  status            MachineStatus   @default(OPERATIONAL)
  lastMaintenanceAt DateTime?       @map("last_maintenance_at")
  nextMaintenanceAt DateTime?       @map("next_maintenance_at")
  installationDate  DateTime?       @map("installation_date")

  // Needle configuration
  needleGauge       Int?            @map("needle_gauge")
  totalNeedleSlots  Int?            @map("total_needle_slots")
  cylinderNeedles   Int?            @map("cylinder_needles")
  dialNeedles       Int?            @map("dial_needles")

  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  cones             YarnCone[]
  productionLogs    ProductionLog[]
  downtimeLogs      DowntimeLog[]
  needleAllocations NeedleMachineAllocation[]
  fabrics           Fabric[]
  products          Product[]  @relation("ProductMachine")
  yarnOutwards      YarnOutward[]
  rolls             Roll[]

  @@index([status])
  @@map("machines")
  @@schema("tenant_template")
}

enum MachineType {
  CIRCULAR_KNITTING
  FLAT_KNITTING
  WARP_KNITTING
  JACQUARD

  @@schema("tenant_template")
}

enum MachineStatus {
  OPERATIONAL
  MAINTENANCE
  BREAKDOWN
  IDLE
  DECOMMISSIONED

  @@schema("tenant_template")
}

model Shift {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(100)
  code           String          @unique @db.VarChar(10)
  startTime      String          @map("start_time") @db.VarChar(5)
  endTime        String          @map("end_time") @db.VarChar(5)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  productionLogs ProductionLog[]
  yarnOutwards   YarnOutward[]

  @@map("shifts")
  @@schema("tenant_template")
}

model ProductionLog {
  id             Int               @id @default(autoincrement())
  machineId      Int               @map("machine_id")
  shiftId        Int               @map("shift_id")
  operatorId     Int?              @map("operator_id")
  productionDate DateTime          @map("production_date") @db.Date
  fabricType     String            @map("fabric_type") @db.VarChar(100)
  targetWeight   Decimal?          @map("target_weight") @db.Decimal(10, 3)
  actualWeight   Decimal           @map("actual_weight") @db.Decimal(10, 3)
  rollsProduced  Int               @default(0) @map("rolls_produced")
  efficiency     Decimal?          @db.Decimal(5, 2)
  defectCount    Int               @default(0) @map("defect_count")
  startTime      DateTime          @map("start_time")
  endTime        DateTime?         @map("end_time")
  totalHours     Decimal?          @map("total_hours") @db.Decimal(5, 2)
  notes          String?           @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  machine        Machine           @relation(fields: [machineId], references: [id])
  shift          Shift             @relation(fields: [shiftId], references: [id])
  consumptions   YarnConsumption[]
  rolls          Roll[]

  @@index([machineId, productionDate])
  @@index([shiftId])
  @@index([productionDate])
  @@map("production_logs")
  @@schema("tenant_template")
}

model YarnConsumption {
  id              Int           @id @default(autoincrement())
  productionLogId Int           @map("production_log_id")
  coneId          Int           @map("cone_id")
  weightBefore    Decimal       @map("weight_before") @db.Decimal(10, 3)
  weightAfter     Decimal       @map("weight_after") @db.Decimal(10, 3)
  weightUsed      Decimal       @map("weight_used") @db.Decimal(10, 3)
  recordedAt      DateTime      @default(now()) @map("recorded_at")
  productionLog   ProductionLog @relation(fields: [productionLogId], references: [id], onDelete: Cascade)
  cone            YarnCone      @relation(fields: [coneId], references: [id])

  @@index([productionLogId])
  @@index([coneId])
  @@map("yarn_consumption")
  @@schema("tenant_template")
}

model DowntimeLog {
  id              Int            @id @default(autoincrement())
  machineId       Int            @map("machine_id")
  reason          DowntimeReason
  description     String?        @db.Text
  startTime       DateTime       @map("start_time")
  endTime         DateTime?      @map("end_time")
  durationMinutes Int?           @map("duration_minutes")
  resolvedBy      Int?           @map("resolved_by")
  resolution      String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  machine         Machine        @relation(fields: [machineId], references: [id])

  @@index([machineId])
  @@index([startTime])
  @@map("downtime_logs")
  @@schema("tenant_template")
}

enum DowntimeReason {
  BREAKDOWN
  MAINTENANCE
  YARN_CHANGE
  POWER_OUTAGE
  NO_OPERATOR
  NO_YARN
  QUALITY_ISSUE
  OTHER

  @@schema("tenant_template")
}

// --- ROLL & GREY STOCK MODULE ---

model Roll {
  id              Int                 @id @default(autoincrement())
  rollNumber      String              @unique @map("roll_number") @db.VarChar(50)
  qrCode          String?             @unique @map("qr_code") @db.VarChar(50)
  productionLogId Int?                @map("production_log_id")
  machineId       Int                 @map("machine_id")
  machine         Machine             @relation(fields: [machineId], references: [id])
  fabricType      String              @map("fabric_type") @db.VarChar(100)

  // Link to Fabric template (for daily production)
  fabricId        Int?                @map("fabric_id")
  fabric          Fabric?             @relation(fields: [fabricId], references: [id])
  width           Decimal?            @db.Decimal(6, 2)
  gsm             Int?
  greyWeight      Decimal             @map("grey_weight") @db.Decimal(10, 3)
  finishedWeight  Decimal?            @map("finished_weight") @db.Decimal(10, 3)
  greyLength      Decimal?            @map("grey_length") @db.Decimal(10, 2)
  finishedLength  Decimal?            @map("finished_length") @db.Decimal(10, 2)
  grade           String              @default("A") @db.VarChar(10)
  defects         Json?
  status          RollStatus          @default(GREY_STOCK)
  currentLocation String?             @map("current_location") @db.VarChar(100)
  producedAt      DateTime            @map("produced_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  productionLog   ProductionLog?      @relation(fields: [productionLogId], references: [id])
  statusHistory   RollStatusHistory[]
  dyeingItems     DyeingOrderItem[]
  saleItems       SaleItem[]

  @@index([status])
  @@index([fabricType])
  @@index([producedAt])
  @@index([fabricId])
  @@map("rolls")
  @@schema("tenant_template")
}

enum RollStatus {
  GREY_STOCK
  SENT_FOR_DYEING
  AT_DYEING
  DYEING_COMPLETE
  FINISHED_STOCK
  SOLD
  REJECTED

  @@schema("tenant_template")
}

model RollStatusHistory {
  id         Int         @id @default(autoincrement())
  rollId     Int         @map("roll_id")
  fromStatus RollStatus? @map("from_status")
  toStatus   RollStatus  @map("to_status")
  changedBy  Int?        @map("changed_by")
  notes      String?     @db.Text
  changedAt  DateTime    @default(now()) @map("changed_at")
  roll       Roll        @relation(fields: [rollId], references: [id], onDelete: Cascade)

  @@index([rollId])
  @@index([changedAt])
  @@map("roll_status_history")
  @@schema("tenant_template")
}

model GreyStockSummary {
  id             Int      @id @default(autoincrement())
  fabricType     String   @map("fabric_type") @db.VarChar(100)
  recordDate     DateTime @map("record_date") @db.Date
  openingRolls   Int      @map("opening_rolls")
  openingWeight  Decimal  @map("opening_weight") @db.Decimal(12, 3)
  producedRolls  Int      @map("produced_rolls")
  producedWeight Decimal  @map("produced_weight") @db.Decimal(12, 3)
  sentForDyeing  Int      @map("sent_for_dyeing")
  sentWeight     Decimal  @map("sent_weight") @db.Decimal(12, 3)
  closingRolls   Int      @map("closing_rolls")
  closingWeight  Decimal  @map("closing_weight") @db.Decimal(12, 3)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([fabricType, recordDate])
  @@index([recordDate])
  @@map("grey_stock_summary")
  @@schema("tenant_template")
}

// --- DYEING MODULE ---

model DyeingVendor {
  id                   Int                 @id @default(autoincrement())
  code                 String              @unique @db.VarChar(50)
  name                 String              @db.VarChar(255)
  contactPerson        String?             @map("contact_person") @db.VarChar(255)
  phone                String?             @db.VarChar(50)
  email                String?             @db.VarChar(255)
  address              String?             @db.Text
  city                 String?             @db.VarChar(100)
  averageTurnaroundDays Int?               @map("average_turnaround_days")
  qualityRating        Decimal?            @map("quality_rating") @db.Decimal(3, 2)
  creditLimit          Decimal?            @map("credit_limit") @db.Decimal(15, 2)
  paymentTerms         Int                 @default(30) @map("payment_terms")
  isActive             Boolean             @default(true) @map("is_active")
  notes                String?             @db.Text
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  dyeingOrders         DyeingOrder[]
  payments             VendorPayment[]
  ledgerEntries        VendorLedgerEntry[]
  materialReceipts     MaterialReceipt[]
  materialReturns      MaterialReturn[]
  cheques              Cheque[]

  @@map("dyeing_vendors")
  @@schema("tenant_template")
}

model GeneralSupplier {
  id              Int                 @id @default(autoincrement())
  code            String              @unique @db.VarChar(50)
  name            String              @db.VarChar(255)
  supplierType    String?             @map("supplier_type") @db.VarChar(100) // e.g., "Needles", "Spare Parts", "Chemicals"
  contactPerson   String?             @map("contact_person") @db.VarChar(255)
  phone           String?             @db.VarChar(50)
  email           String?             @db.VarChar(255)
  address         String?             @db.Text
  city            String?             @db.VarChar(100)
  ntn             String?             @db.VarChar(50)
  strn            String?             @db.VarChar(50)
  creditLimit     Decimal?            @map("credit_limit") @db.Decimal(15, 2)
