enum VendorLedgerType {
  OPENING_BALANCE
  PURCHASE
  PAYMENT_MADE
  RETURN
  ADJUSTMENT
  DEBIT_NOTE
  CREDIT_NOTE

  @@schema("tenant_template")
}

enum ChequeType {
  ISSUED
  RECEIVED

  @@schema("tenant_template")
}

enum ChequeStatus {
  PENDING
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
  REPLACED

  @@schema("tenant_template")
}

enum MaterialReceiptType {
  PURCHASE
  RETURN_IN
  ADJUSTMENT

  @@schema("tenant_template")
}

enum MaterialTransactionType {
  SALE
  RETURN
  SAMPLE
  ADJUSTMENT

  @@schema("tenant_template")
}

enum QualityStatus {
  PENDING_INSPECTION
  APPROVED
  REJECTED
  PARTIAL

  @@schema("tenant_template")
}

enum MaterialIssueType {
  WRONG_TYPE
  QUALITY_DEFECT
  SHORT_WEIGHT
  DAMAGED
  COLOR_MISMATCH
  OTHER

  @@schema("tenant_template")
}

enum ReplacementStatus {
  REPORTED
  RETURN_PENDING
  RETURNED
  REPLACEMENT_PENDING
  REPLACED
  CREDITED
  CLOSED

  @@schema("tenant_template")
