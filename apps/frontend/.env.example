# Mughal Grace Frontend Environment Variables

# API URL - Backend server URL
# Development: http://localhost:3000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Demo Mode - Set to "true" ONLY for demo/preview purposes
# MUST be "false" or unset in production
NEXT_PUBLIC_DEMO_MODE=false

# Development Auth Secret (ONLY for local development)
# Must match DEV_AUTH_SECRET in backend .env
# Leave UNSET in production
# NEXT_PUBLIC_DEV_AUTH_SECRET=your-dev-secret-here
